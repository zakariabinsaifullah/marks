{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "marks/image-accordion-item",
    "version": "1.0.0",
    "title": "Image Accordion Item",
    "category": "marks-blocks",
    "icon": "star-filled",
    "description": "A single panel inside an Image Accordion block.",
    "parent": ["marks/image-accordion"],
    "example": {},
    "supports": {
        "anchor": true,
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true,
            "__experimentalDefaultControls": {
                "margin": false,
                "padding": false
            }
        }
    },
    "attributes": {
        "uniqueId": {
            "type": "string"
        },
        "preset": {
            "type": "string",
            "default": ""
        },
        "image": {
            "type": "object",
            "default": {}
        },
        "heading": {
            "type": "string",
            "default": "Heading"
        },
        "description": {
            "type": "string",
            "default": ""
        },
        "buttonText": {
            "type": "string",
            "default": "Learn More"
        },
        "buttonUrl": {
            "type": "string",
            "default": "#"
        },
        "buttonNewTab": {
            "type": "boolean",
            "default": false
        }
    },
    "textdomain": "marks",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
