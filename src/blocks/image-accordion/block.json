{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "marks/image-accordion",
    "version": "1.0.0",
    "title": "Image Accordion",
    "category": "marks-blocks",
    "icon": "star-filled",
    "description": "Expandable image accordion panels.",
    "example": {},
    "supports": {
        "anchor": true,
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true,
            "__experimentalDefaultControls": {
                "margin": false,
                "padding": false
            }
        }
    },
    "attributes": {
        "uniqueId": {
            "type": "string"
        },
        "newAccordionStatus": {
            "type": "boolean",
            "default": false
        },
        "height": {
            "type": "number",
            "default": 500
        },
        "overlayColor": {
            "type": "string",
            "default": "rgba(18, 100, 100, 0.6)"
        }
    },
    "textdomain": "marks",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js"
}
