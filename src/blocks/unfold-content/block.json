{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "marks/unfold-content",
    "version": "1.0.0",
    "title": "Unfold Content",
    "category": "marks-blocks",
    "icon": "star-filled",
    "description": "Unfold content with customizable items.",
    "example": {},
    "supports": {
        "anchor": true,
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true,
            "__experimentalDefaultControls": {
                "margin": false,
                "padding": false
            }
        }
    },
    "attributes": {
        "uniqueId": {
            "type": "string"
        },
        "contentGap": {
            "type": "number",
            "default": 20
        },
        "itemsGap": {
            "type": "number",
            "default": 0
        }
    },
    "textdomain": "marks",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js"
}
