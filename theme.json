    "styles": {
        "blocks": {
            "core/avatar": {
                "border": {
                    "radius": "100px"
                }
            },
            "core/buttons": {
                "spacing": {
                    "blockGap": "16px"
                }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--accent-5)",
                    "text": "var(--wp--preset--color--marks-neutral-darkest)"
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--marks-40)",
                        "left": "var(--wp--preset--spacing--marks-40)",
                        "right": "var(--wp--preset--spacing--marks-40)",
                        "top": "var(--wp--preset--spacing--marks-40)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fira-code)",
                    "fontSize": "var(--wp--preset--font-size--marks-medium)",
                    "fontWeight": "300"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--marks-50)"
                }
            },
            "core/comment-author-name": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "5px"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)"
                }
            },
            "core/comment-content": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--marks-30)",
                        "top": "var(--wp--preset--spacing--marks-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/comment-date": {
                "color": {
                    "text": "var(--wp--preset--color--marks-neutral-darkest)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--marks-neutral-darkest)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)"
                }
            },
            "core/comment-edit-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--marks-neutral-darkest)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)"
                }
            },
            "core/comment-reply-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--marks-neutral-darkest)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)"
                }
            },
            "core/comments-pagination": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--marks-40)",
                        "top": "var(--wp--preset--spacing--marks-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/comments-pagination-next": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/comments-pagination-numbers": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/comments-pagination-previous": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/list": {
                "css": "& li{margin-top: 0.5rem;}"
            },
            "core/navigation": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--dm-sans)",
                    "fontSize": "var(--wp--preset--font-size--marks-regular)"
                }
            },
            "core/post-comments-form": {
                "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--marks-small); }",
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--marks-40)",
                        "top": "var(--wp--preset--spacing--marks-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)"
                }
            },
            "core/post-navigation-link": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)"
                }
            },
            "core/post-terms": {
                "css": "& a { white-space: nowrap; }",
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-small)",
                    "fontWeight": "600"
                }
            },
            "core/post-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "none"
                            }
                        },
                        "typography": {
                            "fontWeight": "400",
                            "lineHeight": "1.2",
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/pullquote": {
                "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--marks-30);}",
                "elements": {
                    "cite": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--marks-small)",
                            "fontStyle": "normal"
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--marks-30)",
                        "top": "var(--wp--preset--spacing--marks-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-xx-large)",
                    "fontWeight": "300",
                    "lineHeight": "1.2"
                }
            },
            "core/query-pagination": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)",
                    "fontWeight": "500"
                }
            },
            "core/quote": {
                "border": {
                    "color": "currentColor",
                    "style": "solid",
                    "width": "0 0 0 2px"
                },
                "css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
                "elements": {
                    "cite": {
                        "css": "& sub { font-size: 0.65em }",
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--marks-small)",
                            "fontStyle": "normal",
                            "fontWeight": "300"
                        }
                    }
                },
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--marks-30)",
                    "margin": {
                        "left": "0",
                        "right": "0"
                    },
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--marks-30)",
                        "left": "var(--wp--preset--spacing--marks-40)",
                        "right": "var(--wp--preset--spacing--marks-40)",
                        "top": "var(--wp--preset--spacing--marks-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-large)",
                    "fontWeight": "300"
                },
                "variations": {
                    "plain": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "style": "none",
                            "width": "0"
                        },
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    }
                }
            },
            "core/search": {
                "css": "& .wp-block-search__input{border-radius:3.125rem;padding-left:1.5625rem;padding-right:1.5625rem;border-color:var(--wp--preset--color--accent-6);}",
                "elements": {
                    "button": {
                        ":hover": {
                            "border": {
                                "color": "transparent"
                            }
                        },
                        "border": {
                            "radius": "3.125rem"
                        },
                        "spacing": {
                            "margin": {
                                "left": "1.125rem"
                            }
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--marks-medium)",
                    "lineHeight": "1.6"
                }
            },
            "core/separator": {
                "border": {
                    "color": "currentColor",
                    "style": "solid",
                    "width": "0 0 1px 0"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-6)"
                },
                "variations": {
                    "wide": {
                        "css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
                    }
                }
            },
